# PostgreSQL
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_DB=searchdb
POSTGRES_USER=search

# JWT
JWT_SECRET_KEY=change_me_to_random_secret_key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Initial Admin
INITIAL_ADMIN_USERNAME=admin
INITIAL_ADMIN_PASSWORD=change_me_admin_password
INITIAL_ADMIN_EMAIL=admin@localhost

# OpenSearch
OPENSEARCH_URL=http://opensearch:9200

# Redis
REDIS_URL=redis://redis:6379/0

# Database
DATABASE_URL=postgresql+asyncpg://search:change_me_in_production@postgres:5432/searchdb

# Documents
DOCUMENT_ROOT=/data/documents
PREVIEW_CACHE=/data/preview-cache
